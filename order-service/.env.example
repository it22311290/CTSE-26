PORT=3003
NODE_ENV=development
# ⚠️  CHANGE THIS: Your MongoDB connection string for order-service database
# Local:   mongodb://localhost:27017/orderdb
# Atlas:   mongodb+srv://<username>:<password>@<cluster>.mongodb.net/orderdb
MONGODB_URI=mongodb://localhost:27017/orderdb
USER_SERVICE_URL=http://user-service:3001
PRODUCT_SERVICE_URL=http://product-service:3002
PAYMENT_SERVICE_URL=http://payment-service:3004
ALLOWED_ORIGINS=http://localhost:3000
# Must match INTERNAL_SERVICE_KEY in product-service
INTERNAL_SERVICE_KEY=your-secret-service-key
