PORT=3001
NODE_ENV=development
# ⚠️  CHANGE THIS: Your MongoDB connection string for user-service database
# Local:   mongodb://localhost:27017/userdb
# Atlas:   mongodb+srv://<username>:<password>@<cluster>.mongodb.net/userdb
MONGODB_URI=mongodb://localhost:27017/userdb
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:3004
# Must match INTERNAL_SERVICE_KEY across all services
INTERNAL_SERVICE_KEY=your-secret-service-key
